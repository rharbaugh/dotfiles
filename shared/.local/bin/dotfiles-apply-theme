#!/usr/bin/env sh
set -eu

target="${DOTFILES_THEME_TARGET:-${XDG_CONFIG_HOME:-$HOME/.config}}"
system_target="${DOTFILES_SYSTEM_TARGET:-}"
theme_file="${1:-$target/dotfiles/theme.json}"
theme_label="$(basename "$theme_file")"

if ! command -v jq >/dev/null 2>&1; then
  printf '%s\n' "dotfiles-apply-theme requires jq" >&2
  exit 1
fi

color() {
  jq -r ".colors.$1" "$theme_file"
}

strip_hash() {
  printf '%s' "$1" | sed 's/^#//'
}

name="$(jq -r '.name' "$theme_file")"
font_family="$(jq -r '.font_family' "$theme_file")"
tuigreet_theme="$(jq -r '.tuigreet.theme' "$theme_file")"

accent="$(color accent)"
background="$(color background)"
surface="$(color surface)"
foreground="$(color foreground)"
cursor="$(color cursor)"
selection_background="$(color selection_background)"
selection_foreground="$(color selection_foreground)"
critical="$(color critical)"
success="$(color success)"
warning="$(color warning)"
orange="$(color orange)"
purple="$(color purple)"
cyan="$(color cyan)"
muted="$(color muted)"

mkdir -p \
  "$target/ghostty" \
  "$target/mako" \
  "$target/waybar" \
  "$target/hypr/ecosystem" \
  "$target/hypr/lua" \
  "$target/hypr/wallpapers" \
  "$target/greetd"

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf 'background = %s\n' "$background"
  printf 'foreground = %s\n' "$foreground"
  printf 'cursor-color = %s\n' "$cursor"
  printf 'selection-background = %s\n' "$selection_background"
  printf 'selection-foreground = %s\n' "$selection_foreground"
  i=0
  while [ "$i" -le 15 ]; do
    printf 'palette = %s=%s\n' "$i" "$(color "color$i")"
    i=$((i + 1))
  done
} > "$target/ghostty/theme.conf"

{
  printf '%s\n' "/* Generated by dotfiles-apply-theme from $theme_label */"
  printf '@define-color foreground %s;\n' "$foreground"
  printf '@define-color background %s;\n' "$background"
  printf '@define-color surface %s;\n' "$surface"
  printf '@define-color accent %s;\n' "$accent"
  printf '@define-color muted %s;\n' "$muted"
  printf '@define-color warning %s;\n' "$warning"
  printf '@define-color critical %s;\n' "$critical"
  printf '@define-color success %s;\n' "$success"
} > "$target/waybar/theme.css"

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf 'font=%s 10\n' "$font_family"
  printf 'background-color=%s\n' "$background"
  printf 'text-color=%s\n' "$foreground"
  printf 'border-color=%s\n' "$accent"
  printf 'progress-color=over %s\n' "$surface"
  printf 'icons=1\n'
  printf 'max-icon-size=24\n'
  printf 'markup=1\n'
  printf 'actions=1\n'
  printf 'default-timeout=5000\n'
  printf 'ignore-timeout=0\n'
  printf 'width=360\n'
  printf 'height=120\n'
  printf 'margin=8\n'
  printf 'padding=10\n'
  printf 'border-size=1\n'
  printf 'border-radius=4\n'
  printf 'max-visible=5\n'
  printf 'sort=-time\n'
  printf '\n'
  printf '[urgency=low]\n'
  printf 'border-color=%s\n' "$surface"
  printf '\n'
  printf '[urgency=high]\n'
  printf 'border-color=%s\n' "$critical"
  printf 'default-timeout=0\n'
} > "$target/mako/config"

{
  printf '%s\n' "-- Generated by dotfiles-apply-theme from $theme_label"
  printf '%s\n' "return {"
  printf '    name = "%s",\n' "$name"
  printf '    font_family = "%s",\n' "$font_family"
  printf '%s\n' "    colors = {"
  for key in accent background surface foreground cursor selection_background selection_foreground critical success warning orange purple cyan muted; do
    printf '        %s = "%s",\n' "$key" "$(color "$key")"
  done
  printf '%s\n' "    },"
  printf '%s\n' "    hypr = {"
  printf '        accent = "rgba(%see)",\n' "$(strip_hash "$accent")"
  printf '        surface = "rgba(%saa)",\n' "$(strip_hash "$surface")"
  printf '        background = "rgba(%see)",\n' "$(strip_hash "$background")"
  printf '        shadow = "rgba(%s99)",\n' "$(strip_hash "$background")"
  printf '        critical = "rgba(%see)",\n' "$(strip_hash "$critical")"
  printf '%s\n' "    },"
  printf '%s\n' "}"
} > "$target/hypr/lua/theme.lua"

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf '$background = rgb(%s)\n' "$(strip_hash "$background")"
  printf '$surface = rgb(%s)\n' "$(strip_hash "$surface")"
  printf '$foreground = rgb(%s)\n' "$(strip_hash "$foreground")"
  printf '$accent = rgb(%s)\n' "$(strip_hash "$accent")"
  printf '$critical = rgb(%s)\n' "$(strip_hash "$critical")"
  printf '$warning = rgb(%s)\n' "$(strip_hash "$warning")"
  printf '$background_panel = rgba(%scc)\n' "$(strip_hash "$background")"
  printf '$background_input = rgba(%see)\n' "$(strip_hash "$background")"
} > "$target/hypr/ecosystem/hyprlock-theme.conf"

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf 'TUIGREET_THEME=%s\n' "$tuigreet_theme"
} > "$target/greetd/tuigreet-theme.env"

if [ -n "$system_target" ]; then
  mkdir -p "$system_target/greetd"
  {
    printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
    printf '%s\n' "[terminal]"
    printf '%s\n' "vt = 1"
    printf '%s\n' ""
    printf '%s\n' "[default_session]"
    printf 'command = "tuigreet --time --time-format '\''%%A %%H:%%M'\'' --greeting '\''[ %s session ]'\'' --width 72 --remember --remember-session --asterisks --theme '\''%s'\'' --cmd Hyprland"\n' "$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')" "$tuigreet_theme"
    printf '%s\n' 'user = "greeter"'
  } > "$system_target/greetd/config.toml"
fi

if command -v ffmpeg >/dev/null 2>&1; then
  wallpaper="$target/hypr/wallpapers/${name}.png"
  ffmpeg -hide_banner -loglevel error -y \
    -f lavfi -i "color=c=${background}:s=1920x1200" \
    -frames:v 1 "$wallpaper"
  cp "$wallpaper" "$target/hypr/wallpapers/current.png"
fi

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf '%s\n' "splash = false"
  printf '%s\n' "ipc = true"
  printf '%s\n' ""
  printf '%s\n' "wallpaper {"
  printf '%s\n' "    monitor ="
  printf '%s\n' "    path = ~/.config/hypr/wallpapers/current.png"
  printf '%s\n' "    fit_mode = cover"
  printf '%s\n' "}"
} > "$target/hypr/ecosystem/hyprpaper.conf"
