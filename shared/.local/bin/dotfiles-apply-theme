#!/usr/bin/env sh
set -eu

target="${DOTFILES_THEME_TARGET:-${XDG_CONFIG_HOME:-$HOME/.config}}"
system_target="${DOTFILES_SYSTEM_TARGET:-}"
qt_config_target="${DOTFILES_QT_CONFIG_TARGET:-$target}"
theme_file="${1:-$target/dotfiles/theme.json}"
theme_label="$(basename "$theme_file")"

if ! command -v jq >/dev/null 2>&1; then
  printf '%s\n' "dotfiles-apply-theme requires jq" >&2
  exit 1
fi

color() {
  jq -r ".colors.$1" "$theme_file"
}

strip_hash() {
  printf '%s' "$1" | sed 's/^#//'
}

name="$(jq -r '.name' "$theme_file")"
theme_label="$(jq -r 'if .slug then .slug + ".json" else empty end' "$theme_file")"
[ -n "$theme_label" ] || theme_label="$(basename "$theme_file")"
font_family="$(jq -r '.font_family' "$theme_file")"

accent="$(color accent)"
background="$(color background)"
surface="$(color surface)"
foreground="$(color foreground)"
cursor="$(color cursor)"
selection_background="$(color selection_background)"
selection_foreground="$(color selection_foreground)"
critical="$(color critical)"
success="$(color success)"
warning="$(color warning)"
orange="$(color orange)"
purple="$(color purple)"
cyan="$(color cyan)"
muted="$(color muted)"
tuigreet_theme="border=$accent;text=$foreground;prompt=$warning;time=$accent;action=$cyan;button=$warning;container=$background;input=$foreground"

mkdir -p \
  "$target/ghostty" \
  "$target/mako" \
  "$target/qt5ct/colors" \
  "$target/qt6ct/colors" \
  "$target/waybar" \
  "$target/yazi" \
  "$target/hypr/ecosystem" \
  "$target/hypr/lua" \
  "$target/hypr/wallpapers" \
  "$target/greetd"

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf 'background = %s\n' "$background"
  printf 'foreground = %s\n' "$foreground"
  printf 'cursor-color = %s\n' "$cursor"
  printf 'selection-background = %s\n' "$selection_background"
  printf 'selection-foreground = %s\n' "$selection_foreground"
  i=0
  while [ "$i" -le 15 ]; do
    printf 'palette = %s=%s\n' "$i" "$(color "color$i")"
    i=$((i + 1))
  done
} > "$target/ghostty/theme.conf"

{
  printf '%s\n' "/* Generated by dotfiles-apply-theme from $theme_label */"
  printf '@define-color foreground %s;\n' "$foreground"
  printf '@define-color background %s;\n' "$background"
  printf '@define-color surface %s;\n' "$surface"
  printf '@define-color accent %s;\n' "$accent"
  printf '@define-color muted %s;\n' "$muted"
  printf '@define-color warning %s;\n' "$warning"
  printf '@define-color critical %s;\n' "$critical"
  printf '@define-color success %s;\n' "$success"
} > "$target/waybar/theme.css"

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf 'font=%s 10\n' "$font_family"
  printf 'background-color=%s\n' "$background"
  printf 'text-color=%s\n' "$foreground"
  printf 'border-color=%s\n' "$accent"
  printf 'progress-color=over %s\n' "$surface"
  printf 'icons=1\n'
  printf 'max-icon-size=24\n'
  printf 'markup=1\n'
  printf 'actions=1\n'
  printf 'default-timeout=5000\n'
  printf 'ignore-timeout=0\n'
  printf 'width=460\n'
  printf 'height=120\n'
  printf 'margin=8\n'
  printf 'padding=10\n'
  printf 'border-size=1\n'
  printf 'border-radius=4\n'
  printf 'max-visible=5\n'
  printf 'sort=-time\n'
  printf '\n'
  printf '[urgency=low]\n'
  printf 'border-color=%s\n' "$surface"
  printf '\n'
  printf '[urgency=high]\n'
  printf 'border-color=%s\n' "$critical"
  printf 'default-timeout=0\n'
} > "$target/mako/config"

{
  printf '%s\n' "-- Generated by dotfiles-apply-theme from $theme_label"
  printf '%s\n' "return {"
  printf '    name = "%s",\n' "$name"
  printf '    font_family = "%s",\n' "$font_family"
  printf '%s\n' "    colors = {"
  for key in accent background surface foreground cursor selection_background selection_foreground critical success warning orange purple cyan muted; do
    printf '        %s = "%s",\n' "$key" "$(color "$key")"
  done
  printf '%s\n' "    },"
  printf '%s\n' "    hypr = {"
  printf '        accent = "rgba(%see)",\n' "$(strip_hash "$accent")"
  printf '        surface = "rgba(%saa)",\n' "$(strip_hash "$surface")"
  printf '        background = "rgba(%see)",\n' "$(strip_hash "$background")"
  printf '        shadow = "rgba(%s99)",\n' "$(strip_hash "$background")"
  printf '        critical = "rgba(%see)",\n' "$(strip_hash "$critical")"
  printf '%s\n' "    },"
  printf '%s\n' "}"
} > "$target/hypr/lua/theme.lua"

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf '$background = rgb(%s)\n' "$(strip_hash "$background")"
  printf '$surface = rgb(%s)\n' "$(strip_hash "$surface")"
  printf '$foreground = rgb(%s)\n' "$(strip_hash "$foreground")"
  printf '$accent = rgb(%s)\n' "$(strip_hash "$accent")"
  printf '$critical = rgb(%s)\n' "$(strip_hash "$critical")"
  printf '$warning = rgb(%s)\n' "$(strip_hash "$warning")"
  printf '$background_panel = rgba(%scc)\n' "$(strip_hash "$background")"
  printf '$background_input = rgba(%see)\n' "$(strip_hash "$background")"
} > "$target/hypr/ecosystem/hyprlock-theme.conf"

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf 'TUIGREET_THEME=%s\n' "$tuigreet_theme"
} > "$target/greetd/tuigreet-theme.env"

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf '%s\n' "[app]"
  printf 'overall = { bg = "%s" }\n' "$background"
  printf '%s\n' ""
  printf '%s\n' "[mgr]"
  printf 'cwd = { fg = "%s", bold = true }\n' "$accent"
  printf 'find_keyword = { fg = "%s", bold = true }\n' "$warning"
  printf 'find_position = { fg = "%s", bg = "%s" }\n' "$background" "$warning"
  printf 'symlink_target = { fg = "%s" }\n' "$cyan"
  printf 'marker_copied = { fg = "%s", bg = "%s" }\n' "$background" "$success"
  printf 'marker_cut = { fg = "%s", bg = "%s" }\n' "$background" "$critical"
  printf 'marker_marked = { fg = "%s", bg = "%s" }\n' "$background" "$warning"
  printf 'marker_selected = { fg = "%s", bg = "%s" }\n' "$background" "$accent"
  printf 'count_copied = { fg = "%s", bold = true }\n' "$success"
  printf 'count_cut = { fg = "%s", bold = true }\n' "$critical"
  printf 'count_selected = { fg = "%s", bold = true }\n' "$accent"
  printf 'border_symbol = "│"\n'
  printf 'border_style = { fg = "%s" }\n' "$surface"
  printf '%s\n' ""
  printf '%s\n' "[indicator]"
  printf 'parent = { fg = "%s", bg = "%s" }\n' "$muted" "$background"
  printf 'current = { fg = "%s", bg = "%s" }\n' "$background" "$accent"
  printf 'preview = { fg = "%s", bg = "%s" }\n' "$background" "$cyan"
  printf 'padding = { open = "[", close = "]" }\n'
  printf '%s\n' ""
  printf '%s\n' "[tabs]"
  printf 'active = { fg = "%s", bg = "%s", bold = true }\n' "$background" "$accent"
  printf 'inactive = { fg = "%s", bg = "%s" }\n' "$foreground" "$surface"
  printf 'sep_inner = { open = "[", close = "]" }\n'
  printf 'sep_outer = { open = "", close = "" }\n'
  printf '%s\n' ""
  printf '%s\n' "[mode]"
  printf 'normal_main = { fg = "%s", bg = "%s", bold = true }\n' "$background" "$accent"
  printf 'normal_alt = { fg = "%s", bg = "%s" }\n' "$foreground" "$surface"
  printf 'select_main = { fg = "%s", bg = "%s", bold = true }\n' "$background" "$warning"
  printf 'select_alt = { fg = "%s", bg = "%s" }\n' "$foreground" "$surface"
  printf 'unset_main = { fg = "%s", bg = "%s", bold = true }\n' "$background" "$critical"
  printf 'unset_alt = { fg = "%s", bg = "%s" }\n' "$foreground" "$surface"
  printf '%s\n' ""
  printf '%s\n' "[status]"
  printf 'overall = { fg = "%s", bg = "%s" }\n' "$foreground" "$background"
  printf 'sep_left = { open = "", close = "]" }\n'
  printf 'sep_right = { open = "[", close = "" }\n'
  printf 'perm_type = { fg = "%s" }\n' "$accent"
  printf 'perm_read = { fg = "%s" }\n' "$success"
  printf 'perm_write = { fg = "%s" }\n' "$warning"
  printf 'perm_exec = { fg = "%s" }\n' "$critical"
  printf 'perm_sep = { fg = "%s" }\n' "$muted"
  printf 'progress_label = { fg = "%s", bold = true }\n' "$foreground"
  printf 'progress_normal = { fg = "%s", bg = "%s" }\n' "$accent" "$surface"
  printf 'progress_error = { fg = "%s", bg = "%s" }\n' "$critical" "$surface"
  printf '%s\n' ""
  printf '%s\n' "[which]"
  printf 'mask = { bg = "%s" }\n' "$background"
  printf 'cand = { fg = "%s", bold = true }\n' "$accent"
  printf 'rest = { fg = "%s" }\n' "$foreground"
  printf 'desc = { fg = "%s" }\n' "$muted"
  printf 'separator = " -> "\n'
  printf 'separator_style = { fg = "%s" }\n' "$surface"
  printf '%s\n' ""
  printf '%s\n' "[confirm]"
  printf 'border = { fg = "%s" }\n' "$accent"
  printf 'title = { fg = "%s", bold = true }\n' "$warning"
  printf 'body = { fg = "%s" }\n' "$foreground"
  printf 'btn_yes = { fg = "%s", bg = "%s" }\n' "$background" "$success"
  printf 'btn_no = { fg = "%s", bg = "%s" }\n' "$background" "$critical"
  printf 'btn_labels = [" yes ", " no "]\n'
  printf '%s\n' ""
  printf '%s\n' "[notify]"
  printf 'title_info = { fg = "%s", bold = true }\n' "$accent"
  printf 'title_warn = { fg = "%s", bold = true }\n' "$warning"
  printf 'title_error = { fg = "%s", bold = true }\n' "$critical"
  printf '%s\n' ""
  printf '%s\n' "[pick]"
  printf 'border = { fg = "%s" }\n' "$accent"
  printf 'active = { fg = "%s", bg = "%s" }\n' "$background" "$accent"
  printf 'inactive = { fg = "%s" }\n' "$foreground"
  printf '%s\n' ""
  printf '%s\n' "[input]"
  printf 'border = { fg = "%s" }\n' "$accent"
  printf 'title = { fg = "%s", bold = true }\n' "$warning"
  printf 'value = { fg = "%s" }\n' "$foreground"
  printf 'selected = { fg = "%s", bg = "%s" }\n' "$background" "$accent"
  printf '%s\n' ""
  printf '%s\n' "[filetype]"
  printf '%s\n' "rules = ["
  printf '  { mime = "image/*", fg = "%s" },\n' "$warning"
  printf '  { mime = "{audio,video}/*", fg = "%s" },\n' "$purple"
  printf '  { mime = "application/{zip,tar,gzip,xz,zstd,7z,rar}", fg = "%s" },\n' "$orange"
  printf '  { url = "*", is = "orphan", fg = "%s", crossed = true },\n' "$critical"
  printf '  { url = "*", is = "exec", fg = "%s" },\n' "$success"
  printf '  { url = "*/", fg = "%s", bold = true },\n' "$accent"
  printf '  { url = "*", fg = "%s" },\n' "$foreground"
  printf '%s\n' "]"
} > "$target/yazi/theme.toml"

qtct_config() {
  qtct="$1"
  {
    printf '%s\n' "[Appearance]"
    printf 'color_scheme_path=%s/%s/colors/dotfiles-dark.conf\n' "$qt_config_target" "$qtct"
    printf '%s\n' "custom_palette=true"
    printf '%s\n' "icon_theme=Adwaita"
    printf '%s\n' "standard_dialogs=default"
    printf '%s\n' "style=Fusion"
    printf '%s\n' ""
    printf '%s\n' "[Fonts]"
    printf '%s\n' 'fixed="Hack Nerd Font,10,-1,5,50,0,0,0,0,0"'
    printf '%s\n' 'general="Hack Nerd Font,10,-1,5,50,0,0,0,0,0"'
    printf '%s\n' ""
    printf '%s\n' "[Interface]"
    printf '%s\n' "activate_item_on_single_click=1"
    printf '%s\n' "buttonbox_layout=0"
    printf '%s\n' "cursor_flash_time=1000"
    printf '%s\n' "dialog_buttons_have_icons=1"
    printf '%s\n' "double_click_interval=400"
    printf '%s\n' "gui_effects=@Invalid()"
    printf '%s\n' "keyboard_scheme=2"
    printf '%s\n' "menus_have_icons=true"
    printf '%s\n' "show_shortcuts_in_context_menus=true"
    printf '%s\n' "stylesheets=@Invalid()"
    printf '%s\n' "toolbutton_style=4"
    printf '%s\n' "underline_shortcut=1"
    printf '%s\n' "wheel_scroll_lines=3"
  } > "$target/$qtct/$qtct.conf"
}

qtct_colors() {
  qtct="$1"
  color_path="$target/$qtct/colors/dotfiles-dark.conf"
  {
    printf '%s\n' "[ColorScheme]"
    printf 'active_colors=#ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ffffffff, #ff%s, #ff%s, #ff%s, #ff000000, #ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ffffffff, #ff%s, #ff%s, #80%s\n' \
      "$(strip_hash "$foreground")" "$(strip_hash "$surface")" "$(strip_hash "$muted")" "$(strip_hash "$surface")" "$(strip_hash "$background")" "$(strip_hash "$background")" "$(strip_hash "$foreground")" "$(strip_hash "$foreground")" "$(strip_hash "$background")" "$(strip_hash "$background")" "$(strip_hash "$accent")" "$(strip_hash "$foreground")" "$(strip_hash "$accent")" "$(strip_hash "$critical")" "$(strip_hash "$surface")" "$(strip_hash "$background")" "$(strip_hash "$foreground")" "$(strip_hash "$foreground")"
    printf 'disabled_colors=#ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ffffffff, #ff%s, #ff%s, #ff%s, #ff000000, #ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ffffffff, #ff%s, #ff%s, #80%s\n' \
      "$(strip_hash "$muted")" "$(strip_hash "$surface")" "$(strip_hash "$surface")" "$(strip_hash "$surface")" "$(strip_hash "$background")" "$(strip_hash "$background")" "$(strip_hash "$muted")" "$(strip_hash "$muted")" "$(strip_hash "$background")" "$(strip_hash "$background")" "$(strip_hash "$surface")" "$(strip_hash "$muted")" "$(strip_hash "$surface")" "$(strip_hash "$critical")" "$(strip_hash "$surface")" "$(strip_hash "$background")" "$(strip_hash "$foreground")" "$(strip_hash "$muted")"
    printf 'inactive_colors=#ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ffffffff, #ff%s, #ff%s, #ff%s, #ff000000, #ff%s, #ff%s, #ff%s, #ff%s, #ff%s, #ffffffff, #ff%s, #ff%s, #80%s\n' \
      "$(strip_hash "$foreground")" "$(strip_hash "$surface")" "$(strip_hash "$muted")" "$(strip_hash "$surface")" "$(strip_hash "$background")" "$(strip_hash "$background")" "$(strip_hash "$foreground")" "$(strip_hash "$foreground")" "$(strip_hash "$background")" "$(strip_hash "$background")" "$(strip_hash "$surface")" "$(strip_hash "$foreground")" "$(strip_hash "$surface")" "$(strip_hash "$critical")" "$(strip_hash "$surface")" "$(strip_hash "$background")" "$(strip_hash "$foreground")" "$(strip_hash "$foreground")"
  } > "$color_path"
}

for qtct in qt5ct qt6ct; do
  qtct_config "$qtct"
  qtct_colors "$qtct"
done

if [ -n "$system_target" ]; then
  mkdir -p "$system_target/greetd"
  {
    printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
    printf '%s\n' "[terminal]"
    printf '%s\n' "vt = 1"
    printf '%s\n' ""
    printf '%s\n' "[default_session]"
    printf 'command = "tuigreet --time --time-format '\''%%A %%H:%%M'\'' --width 72 --remember --remember-session --asterisks --theme '\''%s'\'' --cmd '\''uwsm start hyprland.desktop'\''"\n' "$tuigreet_theme"
    printf '%s\n' 'user = "greeter"'
  } > "$system_target/greetd/config.toml"
fi

if command -v ffmpeg >/dev/null 2>&1; then
  wallpaper="$target/hypr/wallpapers/${name}.png"
  ffmpeg -hide_banner -loglevel error -y \
    -f lavfi -i "color=c=${background}:s=1920x1200" \
    -frames:v 1 "$wallpaper"
  cp "$wallpaper" "$target/hypr/wallpapers/current.png"
fi

{
  printf '%s\n' "# Generated by dotfiles-apply-theme from $theme_label"
  printf '%s\n' "splash = false"
  printf '%s\n' "ipc = true"
  printf '%s\n' ""
  printf '%s\n' "wallpaper {"
  printf '%s\n' "    monitor ="
  printf '%s\n' "    path = ~/.config/hypr/wallpapers/current.png"
  printf '%s\n' "    fit_mode = cover"
  printf '%s\n' "}"
} > "$target/hypr/ecosystem/hyprpaper.conf"
