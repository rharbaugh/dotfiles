#!/usr/bin/env sh
set -eu

choose_with_shell() {
  printf '%s\n' "[ power ]"
  select action in lock logout restart sleep hibernate shutdown; do
    [ -n "$action" ] && printf '%s\n' "$action" && return
  done
}

choose_with_walker() {
  printf '%s\n' lock logout restart sleep hibernate shutdown | walker --dmenu
}

if command -v walker >/dev/null 2>&1; then
  action="$(choose_with_walker)"
else
  action="$(choose_with_shell)"
fi

[ -n "$action" ] || exit 0
exec dotfiles-power "$action"
