#!/usr/bin/env bash
set -euo pipefail

if (( EUID != 0 )); then
  echo "install-system must be run as root" >&2
  exit 1
fi

repo="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

packages=(
  avahi
  bat
  bluez
  bluez-obex
  bluez-utils
  bluetui
  brightnessctl
  btop
  cups
  cups-browsed
  adwaita-icon-theme
  dconf
  fd
  ffmpeg
  fzf
  grim
  ghostty
  git
  gst-libav
  gst-plugins-bad
  gst-plugins-base
  gst-plugins-good
  gst-plugins-ugly
  greetd
  hypridle
  hyprland
  hyprlock
  hyprpaper
  hyprpolkitagent
  hyprshutdown
  hyprsunset
  ipp-usb
  jq
  keychain
  mako
  man-db
  man-pages
  mpv
  mpv-mpris
  neovim
  networkmanager
  ncspot
  noto-fonts
  noto-fonts-cjk
  noto-fonts-emoji
  noto-fonts-extra
  nss-mdns
  openssh
  playerctl
  pipewire
  pipewire-alsa
  pipewire-audio
  pipewire-jack
  pipewire-pulse
  power-profiles-daemon
  qt5-wayland
  qt5ct
  qt6-wayland
  qt6ct
  sane
  sane-airscan
  shikane
  slurp
  starship
  spotify-player
  stow
  system-config-printer
  termusic
  ttf-hack-nerd
  greetd-tuigreet
  uwsm
  vlc
  vlc-gui-ncurses
  vlc-plugins-all
  waybar
  wget
  wireguard-tools
  wireplumber
  wl-clipboard
  woff2-font-awesome
  wofi
  xdg-desktop-portal
  xdg-desktop-portal-gtk
  xdg-desktop-portal-hyprland
  eza
  ripgrep
  yazi
  yt-dlp
  yubikey-manager
  zsh
  zoxide
)

pacman -S --needed "${packages[@]}"
pacman -D --asexplicit "${packages[@]}"

if [[ -f /etc/greetd/config.toml && ! -f /etc/greetd/config.toml.bak ]]; then
  cp /etc/greetd/config.toml /etc/greetd/config.toml.bak
fi

install -Dm644 "$repo/system/etc/greetd/config.toml" /etc/greetd/config.toml
install -Dm644 "$repo/system/etc/systemd/sleep.conf.d/10-dotfiles-hibernate.conf" /etc/systemd/sleep.conf.d/10-dotfiles-hibernate.conf

systemctl enable --now NetworkManager.service
systemctl enable --now bluetooth.service
systemctl enable --now cups.service
systemctl enable --now avahi-daemon.service
systemctl enable --now cups-browsed.service
systemctl enable --now greetd.service

if systemctl list-unit-files sddm.service >/dev/null 2>&1; then
  systemctl disable --now sddm.service || true
fi

echo "System packages and services installed."
echo "Run './scripts/restow-shared' as the user to apply home dotfiles."
