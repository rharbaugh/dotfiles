#!/usr/bin/env bash
set -euo pipefail

if (( EUID != 0 )); then
  echo "install-system must be run as root" >&2
  exit 1
fi

repo="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
profile="${1:-laptop}"

case "$profile" in
  laptop|desktop) ;;
  *)
    echo "usage: install-system [laptop|desktop]" >&2
    exit 2
    ;;
esac

packages=(
  avahi
  bat
  bluez
  bluez-obex
  bluez-utils
  bluetui
  brightnessctl
  btop
  cups
  cups-browsed
  adwaita-icon-theme
  dconf
  fd
  ffmpeg
  ffmpegthumbnailer
  firefox
  fwupd
  fzf
  grim
  ghostty
  git
  gnupg
  gst-libav
  gst-plugins-bad
  gst-plugins-base
  gst-plugins-good
  gst-plugins-ugly
  greetd
  hypridle
  hyprland
  hyprlock
  hyprpaper
  hyprpolkitagent
  hyprshutdown
  hyprsunset
  ipp-usb
  imv
  jq
  keychain
  libreoffice-fresh
  mako
  man-db
  man-pages
  mpv
  mpv-mpris
  neovim
  networkmanager
  ncspot
  noto-fonts
  noto-fonts-cjk
  noto-fonts-emoji
  noto-fonts-extra
  nss-mdns
  openssh
  playerctl
  pipewire
  pipewire-alsa
  pipewire-audio
  pipewire-jack
  pipewire-pulse
  pinentry
  power-profiles-daemon
  qt5-wayland
  qt5ct
  qt6-wayland
  qt6ct
  rbw
  sane
  sane-airscan
  slurp
  starship
  spotify-player
  stow
  system-config-printer
  termusic
  ttf-hack-nerd
  greetd-tuigreet
  uwsm
  vlc
  vlc-gui-ncurses
  vlc-plugins-all
  waybar
  wget
  wireguard-tools
  wiremix
  wireplumber
  wl-clipboard
  woff2-font-awesome
  wofi
  xdg-desktop-portal
  xdg-desktop-portal-gtk
  xdg-desktop-portal-hyprland
  eza
  ripgrep
  udisks2
  usbutils
  yazi
  yt-dlp
  yubikey-manager
  zsh
  zoxide
  zathura
  zathura-pdf-mupdf
)

profile_packages=()

case "$profile" in
  laptop)
    profile_packages=(
      framework-system
      shikane
    )
    ;;
  desktop)
    profile_packages=()
    ;;
esac

pacman -S --needed "${packages[@]}" "${profile_packages[@]}"
pacman -D --asexplicit "${packages[@]}" "${profile_packages[@]}"

if [[ -f /etc/greetd/config.toml && ! -f /etc/greetd/config.toml.bak ]]; then
  cp /etc/greetd/config.toml /etc/greetd/config.toml.bak
fi

install -Dm644 "$repo/system/etc/greetd/config.toml" /etc/greetd/config.toml
install -Dm644 "$repo/system/etc/vtrgb-dotfiles" /etc/vtrgb-dotfiles
install -Dm644 "$repo/system/etc/systemd/system/greetd.service.d/10-dotfiles-vtrgb.conf" /etc/systemd/system/greetd.service.d/10-dotfiles-vtrgb.conf

if [[ "$profile" == "laptop" ]]; then
  install -Dm644 "$repo/system-laptop/etc/systemd/sleep.conf.d/10-dotfiles-hibernate.conf" /etc/systemd/sleep.conf.d/10-dotfiles-hibernate.conf
  install -Dm644 "$repo/system-laptop/etc/systemd/system/battery-limit.service" /etc/systemd/system/battery-limit.service
fi

systemctl daemon-reload
setvtrgb /etc/vtrgb-dotfiles || true

systemctl enable --now NetworkManager.service
systemctl enable --now bluetooth.service
systemctl enable --now cups.service
systemctl enable --now avahi-daemon.service
systemctl enable --now cups-browsed.service
systemctl enable --now greetd.service

if [[ "$profile" == "laptop" ]]; then
  systemctl enable --now battery-limit.service
fi

if systemctl list-unit-files sddm.service >/dev/null 2>&1; then
  systemctl disable --now sddm.service || true
fi

echo "System packages and services installed."
echo "Run './scripts/restow-shared $profile' as the user to apply home dotfiles."
