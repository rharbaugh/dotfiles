#!/usr/bin/env sh
set -eu

usage() {
  printf '%s\n' "usage: battery-limit {status|power|80|100|0-100}" >&2
  exit 2
}

need_framework_tool() {
  if ! command -v framework_tool >/dev/null 2>&1; then
    printf '%s\n' "battery-limit requires framework-system / framework_tool" >&2
    exit 1
  fi
}

run_framework_tool() {
  if [ "$(id -u)" -eq 0 ]; then
    framework_tool "$@"
  else
    sudo framework_tool "$@"
  fi
}

need_framework_tool

case "${1:-status}" in
  status)
    run_framework_tool --charge-limit
    ;;
  power)
    run_framework_tool --power
    ;;
  ''|*[!0-9]*)
    usage
    ;;
  *)
    if [ "$1" -lt 0 ] || [ "$1" -gt 100 ]; then
      usage
    fi
    run_framework_tool --charge-limit "$1"
    ;;
esac
